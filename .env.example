# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# EVOLUTION API: Credentials for WhatsApp Business integration (Evolution API / Evolution Go)
EVOLUTION_API_URL="https://api.evolution-api.com"
EVOLUTION_API_KEY=""
EVOLUTION_INSTANCE="SST_Whats_Alerts"

# N8N: Webhook URL for SST automation workflow triggers
N8N_WEBHOOK_URL="https://n8n.novo-horizonte.com.br/webhook/sst"

# S3 COMPATIBLE BACKUP STORE CONFIGURATION (AWS S3, MinIO, Cloudflare R2)
S3_ENDPOINT="https://s3.us-east-1.amazonaws.com"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET_NAME=""
S3_REGION="us-east-1"
